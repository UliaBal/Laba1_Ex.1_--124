<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Card game</title>
    <style>
        .block{
        display: inline-block;
        font-size: 40px;
        background: #e7e7e7;
        } 
        .red{
            color: #990000;
        }
        .black{
            color: black;
        }
    </style>
</head>
<body>
    <p>Player 1:</p>
    <div class="block black">2&clubs;</div>
    <div class="block red">9&hearts;</div>
    <div class="block red">6&hearts;</div>
    <div class="block red">A&diams;</div>
    <div class="block black">Q&spades;</div>
    <div class="block black">J&clubs;</div>
    <p>Player 2:</p>
    <div class="block red">3&hearts;</div>
    <div class="block black">A&clubs;</div>
    <div class="block black">10&clubs;</div>
    <div class="block red">K&diams;</div> 
    <div class="block black">8&spades;</div>
    <div class="block red">3&hearts;</div>
</body>
</html>
